# Clipboard
set selection-clipboard "clipboard"

# UI minimalism
set statusbar-h-padding 5
set statusbar-v-padding 5
set scroll-bar true

# Navigation (controlled, no large jumps)
map j scroll down
map k scroll up
map h scroll left
map l scroll right
map d scroll 20
map u scroll -20
map g navigate top
map G navigate bottom
map i toggle_index

# Remove problematic key
# map <C-h> feedkeys "a h"   # unnecessary, causes input overhead

# Rendering behavior
set smooth-scroll false
set scroll-step 30
set zoom-step 10

# Layout
set pages-per-row 1
set page-padding 0
set adjust-open "best-fit"

# Zoom bounds
set zoom-min 0.5
set zoom-max 900

# Status info
set statusbar-home-tilde true
set statusbar-basename true

# Performance-critical: disable recolor
set recolor false
set recolor-keephue true
set recolor-lightcolor "#2E3440"
set recolor-darkcolor "#D8DEE9"

# Fonts
set font "IBM Plex Mono 10"
set default-fallback-font "IBM Plex Mono 10"

# Memory + text
set use-less-memory false
set enable-hyphenation true

# SyncTeX
set synctex true
set synctex-editor-command "nvim --headless -c 'VimtexInverseSearch %l %f'"

# External theme
include mono 
