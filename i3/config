set $mod Mod4
font pango:JetBrains Mono Nerd Font  9.5
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
set $refresh_i3status killall -SIGUSR1 i3status

floating_modifier $mod
tiling_drag modifier titlebar

# Volume control:
bindsym XF86AudioRaiseVolume exec --no-startup-id "pactl set-sink-volume @DEFAULT_SINK@ +10%; killall -SIGUSR1 i3status"
bindsym XF86AudioLowerVolume exec --no-startup-id "pactl set-sink-volume @DEFAULT_SINK@ -10%; killall -SIGUSR1 i3status"
bindsym XF86AudioMute exec --no-startup-id "pactl set-sink-mute @DEFAULT_SINK@ toggle; killall -SIGUSR1 i3status"
bindsym XF86AudioMicMute exec --no-startup-id "pactl set-source-mute @DEFAULT_SOURCE@ toggle; killall -SIGUSR1 i3status"

# Brightness control:
bindsym XF86MonBrightnessDown exec brightnessctl s 10%-
bindsym XF86MonBrightnessUp exec brightnessctl s 10%+

# Applications shortcuts:
bindsym $mod+Shift+d exec kclock
bindsym $mod+Shift+Return exec zen-browser 
bindsym $mod+Return exec alacritty 
bindsym $mod+Shift+m exec strawberry 
bindsym $mod+Shift+g exec ~/scripts/define.sh

# Cycling to previously used workspace:
bindsym $mod+Tab workspace back_and_forth

# bindsym $mod+d exec --no-startup-id dmenu_run  -fn 'FiraMono Nerd Font:size=11' -nb '#111111' -nf '#ffffff' -sb '#285577' -sf '#ffffff'
bindsym $mod+d exec --no-startup-id rofi -show drun

# Changing focus between windows:
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

# Moving the window:
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Horizontal & Vertical split:
bindsym $mod+h split h
bindsym $mod+v split v

# Window tiling configuration:
focus_follows_mouse no
mouse_warping none
# Disable universal floating toggle
for_window [class=".*"] floating disable 
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+q kill

# toggle tiling / floating
# bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Switch to workspace:
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move focused container to workspace:
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# i3-wm specific window manager tweaks:
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Did you actually mean to press that?' -B 'Yes' 'i3-msg exit'"
bindsym $mod+r mode "resize"

# Script commands, programs:
bindsym $mod+Shift+p exec flameshot gui 
bindsym $mod+p exec ~/scripts/emoji.sh
exec "xautolock -detectsleep -time 10 -locker \"i3lock -c '#000000'\""
bindsym Control+Mod1+1 exec "i3lock -c '#000000'"
bindsym $mod+Shift+w exec --no-startup-id ~/scripts/wallpaper_switcher.sh


# resize window (you can also use the mouse for that)
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

# Set inner gaps between windows
gaps inner 0
# Set outer gaps between the edge of the screen and windows
gaps outer 0
# Smart Gaps (Only gaps when you have =< 2 windows open in a single workspace)
smart_gaps off 

# Window classes configuration:
for_window [class="nsxiv"] floating enable
for_window [class="nsxiv"] resize set 1000 700
for_window [class="nsxiv"] move position center
for_window [class=".*"] border normal
# hide_edge_borders smart
default_border normal
default_floating_border normal

# class                 border  backgr. text    indicator child_border
client.focused          #285577 #285577 #ffffff #285577   #285577
client.focused_inactive #32302F  #32302F  #BDAE93  #32302F  #32302F
client.unfocused        #282828  #282828  #A89984  #282828  #282828
client.urgent           #ea6962 #ea6962 #1d2021 #ea6962   #ea6962
client.placeholder      #000000 #0c0c0c #ffffff #000000   #0c0c0c
client.background       #ffffff

# i3-status bar configuration:
bar {
    font pango:JetBrains Mono Nerd Font 9.5
    status_command i3status
    tray_output primary
    position bottom 
    separator_symbol "/"
}


# Startup services:
exec_always --no-startup-id feh --randomize --bg-fill ~/Pictures/wallpapers/#0f0f0f.png &
exec --no-startup-id dunst &
exec --no-startup-id udiskie --tray &
